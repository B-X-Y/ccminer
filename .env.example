# ================================
# CCMiner Configuration
# ================================

# Mining algorithm
# Refer to README.txt for supported algorithms
ALG=algorithm

# Mining pool endpoint
# Format:
#   stratum+tcp://host:port
POOL=stratum+tcp://pool.example.com:3333

# Wallet address or pool account
# Optional worker suffix
MINER_USER=account.worker

# Pool password
MINER_PASS=x
